---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getSortedPosts } from '../../utils';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const publishedEntries = getSortedPosts(blogEntries);
  const internalBlogEntries = publishedEntries.filter(entry => !entry.data.externalUrl);
  return internalBlogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BlogPost
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  modDate={entry.data.modDate}
  tags={entry.data.tags}
  ogImage={entry.data.ogImage}
  canonicalURL={entry.data.canonicalURL}
  body={entry.body}
>
  <Content />
</BlogPost>
