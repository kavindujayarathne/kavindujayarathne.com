---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import BlogListItem from '../../components/BlogListItem.astro';
import { SITE } from '../../config';
import { getSortedPosts } from '../../utils';

const allBlogPosts = await getCollection('blog');
const sortedPosts = getSortedPosts(allBlogPosts);
---

<PageLayout title={`Blog | ${SITE.title}`} description={SITE.blogDescription}>
  <div class="content-container align-top">
    <div class="page-header">
      <h1>Blogs</h1>
      <p class="tagline">Writings on things I've explored and understood</p>
    </div>
    {sortedPosts.length > 0 ? (
      <ul class="blog-list">
        {sortedPosts.map(post => (
          <BlogListItem post={post} />
        ))}
      </ul>
    ) : (
      <p class="coming-soon">
        Blog posts coming soon! Stay tuned for articles about computer science, programming, and technology.
      </p>
    )}
  </div>
</PageLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-style: italic;
    color: var(--text-color);
    margin-bottom: 0.25rem;
  }

  .blog-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

</style>
