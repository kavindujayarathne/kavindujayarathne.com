---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allBlogPosts = await getCollection('blog');
  
  // Get all unique tags
  const uniqueTags = [...new Set(allBlogPosts.flatMap(post => post.data.tags))];
  
  // Create a path for each tag
  return uniqueTags.map(tag => {
    // Filter posts that include the current tag
    const filteredPosts = allBlogPosts.filter(post => 
      post.data.tags.map(t => t.toLowerCase()).includes(tag.toLowerCase())
    );
    
    return {
      params: { tag: tag.toLowerCase() },
      props: { posts: filteredPosts, tag }
    };
  });
}

const { posts, tag } = Astro.props;
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<Layout title={`${tag} | Kavindu Jayarathne`} description={`Blog posts tagged with ${tag}`}>
  <section class="tag-page">
    <h2>Posts tagged with <span class="highlight">{tag}</span></h2>
    
    <div class="tag-content">
      {sortedPosts.length > 0 ? (
        <ul class="blog-list">
          {sortedPosts.map(post => (
            <li class="blog-item">
              <article>
                <div class="blog-header">
                  <h2 class="blog-title">
                    <a href={`/blogs/${post.slug}`}>{post.data.title}</a>
                  </h2>
                  <time class="blog-date">{new Date(post.data.pubDate).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}</time>
                </div>
                <p class="blog-excerpt">{post.data.description}</p>
                <div class="blog-tags">
                  {post.data.tags.map(t => (
                    <a href={`/tags/${t.toLowerCase()}`} class={`tag ${t.toLowerCase() === tag.toLowerCase() ? 'active' : ''}`}>{t}</a>
                  ))}
                </div>
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p class="no-posts">No posts found with this tag.</p>
      )}
      
      <div class="back-link">
        <a href="/blogs">&larr; Back to all posts</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .tag-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--section-padding);
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }

  .highlight {
    color: var(--accent-color);
  }

  .blog-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .blog-item {
    margin-bottom: 0.5rem;
  }

  .blog-header {
    display: flex;
    flex-direction: column;
    margin-bottom: 0.5rem;
  }

  .blog-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }

  .blog-title a {
    color: var(--text-color);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-title a:hover {
    color: var(--accent-color);
  }

  .blog-date {
    font-size: 0.9rem;
    color: var(--secondary-color);
    margin-top: 0.25rem;
  }

  .blog-excerpt {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--secondary-color);
    margin: 0.5rem 0;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.8rem;
    background-color: rgba(100, 255, 218, 0.1);
    color: var(--accent-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .tag:hover {
    background-color: rgba(100, 255, 218, 0.2);
  }

  .tag.active {
    background-color: rgba(100, 255, 218, 0.3);
    font-weight: 600;
  }

  .no-posts {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--secondary-color);
    text-align: center;
    padding: 3rem 0;
  }

  .back-link {
    margin-top: 2.5rem;
  }

  .back-link a {
    color: var(--secondary-color);
    transition: color 0.3s ease;
  }

  .back-link a:hover {
    color: var(--accent-color);
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 1.3rem;
    }

    .blog-title {
      font-size: 1.3rem;
    }
  }
</style>