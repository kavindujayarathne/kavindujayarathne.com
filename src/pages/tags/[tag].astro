---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BlogListItem from '../../components/BlogListItem.astro';
import { SITE } from '../../config';
import { getSortedPosts, getPostsByTag, slugifyTag } from '../../utils';
import LeftArrowIcon from '../../assets/icons/LeftArrowIcon.svg?raw';

export async function getStaticPaths() {
  const allBlogPosts = await getCollection('blog');

  const uniqueTags = [...new Set(allBlogPosts.flatMap(post => post.data.tags))];

  return uniqueTags.map(tag => {
    const filteredPosts = getPostsByTag(allBlogPosts, tag);

    return {
      params: { tag: slugifyTag(tag) },
      props: { posts: filteredPosts, tag }
    };
  });
}

const { posts, tag } = Astro.props;
const sortedPosts = getSortedPosts(posts);
---

<Layout title={`${tag} | ${SITE.title}`} description={`Blog posts tagged with ${tag}`}>
  <div class="content-container align-top">
    <h2>Posts tagged with <span class="highlight">{tag}</span></h2>
    
    <div class="tag-content">
      {sortedPosts.length > 0 ? (
        <ul class="blog-list">
          {sortedPosts.map(post => (
            <BlogListItem post={post} activeTag={tag} />
          ))}
        </ul>
      ) : (
        <p class="no-posts">No posts found with this tag.</p>
      )}

      <a href="/blogs" class="arrow-link"><Fragment set:html={LeftArrowIcon} /> Back to all posts</a>
    </div>
  </div>
</Layout>

<style>
  h2 {
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }

  .highlight {
    color: var(--accent-color);
  }

  .blog-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .no-posts {
    font-size: var(--fs-base);
    line-height: 1.8;
    color: var(--secondary-color);
    text-align: center;
    padding: 3rem 0;
  }
</style>
