---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE } from '../config';
import LeftArrowIcon from '../assets/icons/LeftArrowIcon.svg?raw';
---

<PageLayout title={`404: Page Not Found | ${SITE.title}`} description="The page you're looking for doesn't exist.">
  <div class="error-page content-container">
    <div>
      <h1>404</h1>
      <h2>Page Not Found</h2>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="arrow-link">
        <Fragment set:html={LeftArrowIcon} /> Back to home
      </a>
    </div>
  </div>
</PageLayout>

<style>
  .error-page {
    text-align: center;
  }

  h1 {
    font-size: var(--fs-display);
    font-weight: 700;
    color: var(--accent-color);
    margin: 0;
    line-height: 1;
    opacity: 0.8;
  }

  h2 {
    font-size: var(--fs-4xl);
    color: var(--text-color);
    margin: 1rem 0;
  }

  p {
    font-size: var(--fs-base);
    color: var(--secondary-color);
    margin-bottom: 2rem;
  }

</style>
