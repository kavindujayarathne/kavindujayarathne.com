---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found | Kavindu Jayarathne" description="The page you're looking for doesn't exist.">
  <section class="error-page">
    <div class="error-content">
      <h1>404</h1>
      <h2>Page Not Found</h2>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="back-link">
        ← Back to home
      </a>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height) - 120px);
    text-align: center;
    padding: 2rem;
  }

  .error-content {
    max-width: 600px;
  }

  h1 {
    font-size: 8rem;
    font-weight: 700;
    color: var(--accent-color);
    margin: 0;
    line-height: 1;
    opacity: 0.8;
  }

  h2 {
    font-size: 2rem;
    color: var(--text-color);
    margin: 1rem 0;
  }

  p {
    font-size: 1.1rem;
    color: var(--secondary-color);
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    color: var(--secondary-color);
    text-decoration: none;
    font-size: 1.1rem;
    transition: color var(--transition-speed) ease;
  }

  .back-link:hover {
    color: var(--accent-color);
  }
</style>