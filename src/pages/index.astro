---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Kavindu Jayarathne | Personal Website">
  <div class="content-container">
    <div class="hero-content">
      <div class="profile-image">
        <img src="/splash_low.png" alt="Kavindu Jayarathne" />
      </div>
      <div class="intro-text">
        <h1>Hey, Welcome!</h1>
        <p>
          My name is <span class="highlight">Kavindu</span>.<br />
          I build things, break things, build things that breaks things.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-content {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    text-align: left;
  }

  .profile-image {
    max-width: 300px;
  }

  .profile-image img {
    width: 100%;
    height: auto;
  }

  .intro-text h1 {
    /* font-size: 2.5rem; */
    font-size: 2rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .intro-text p {
    /* font-size: 1.2rem; */
    font-size: 1rem;
    line-height: 1.6;
    color: var(--secondary-color);
  }

  .highlight {
    color: var(--accent-color);
    font-weight: 600;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }

    .profile-image {
      max-width: 200px;
    }

    .intro-text h1 {
      font-size: 2rem;
    }

    .intro-text p {
      font-size: 1.1rem;
    }
  }
</style>
