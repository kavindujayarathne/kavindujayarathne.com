---
import PageLayout from '../layouts/PageLayout.astro';
import { projects } from '../data/projects';
import { SITE } from '../config';

const sortedProjects = [...projects].sort(
  (a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);
---

<PageLayout
  title={`Projects | ${SITE.title}`}
  description={`Explore ${SITE.author}'s projects and portfolio work.`}
>
  <div class="content-container align-top">
    <div class="page-header">
      <h1>Projects</h1>
      <p class="tagline">Things I've built along the way</p>
    </div>

    {sortedProjects.length > 0 ? (
      <ul class="projects-list" data-pagefind-body>
        {sortedProjects.map(project => (
          <li class="project-item">
            <article>
              <div class="project-header">
                <h2 class="project-title">{project.title}</h2>
                <span class={`project-status status-${project.status}`}>{project.status}</span>
              </div>
              <p class="project-description">{project.description}</p>
              <div class="project-tags">
                {project.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <div class="project-links prose">
                {project.links.map(link => (
                  <a
                    href={link.url}
                    class="project-link"
                    target={link.url.startsWith('/') ? undefined : '_blank'}
                    rel={link.url.startsWith('/') ? undefined : 'noopener noreferrer'}
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </article>
          </li>
        ))}
      </ul>
    ) : (
      <p class="coming-soon">
        Projects coming soon! Stay tuned for things I'm building.
      </p>
    )}
  </div>
</PageLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-style: italic;
    color: var(--text-color);
    margin-bottom: 0.25rem;
  }

  .projects-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-title {
    font-weight: 600;
    margin: 0;
    color: var(--text-color);
  }

  .project-status {
    font-size: var(--fs-xs);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    text-transform: lowercase;
  }

  .status-active {
    background-color: var(--tag-bg);
    color: var(--accent-color);
  }

  .status-archived {
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--secondary-color);
  }

  .status-wip {
    background-color: rgba(255, 193, 7, 0.1);
    color: #ffc107;
  }

  .project-description {
    font-size: var(--fs-base);
    line-height: 1.6;
    color: var(--secondary-color);
    margin: 0 0 0.5rem 0;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
  }

  .tag {
    font-size: var(--fs-sm);
    background-color: var(--tag-bg);
    color: var(--accent-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: background-color var(--transition-speed) ease;
  }

  .tag:hover {
    background-color: var(--tag-hover-bg);
  }

  .project-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .project-link {
    font-size: var(--fs-base);
  }

</style>
