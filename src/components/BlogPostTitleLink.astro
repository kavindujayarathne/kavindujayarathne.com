---
export interface Props {
  title: string;
  slug: string;
  externalUrl?: string;
}

const { title, slug, externalUrl } = Astro.props;
---

<h2 class="blog-title">
  <a
    href={externalUrl || `/blogs/${slug}`}
    target={externalUrl ? "_blank" : undefined}
    rel={externalUrl ? "noopener noreferrer" : undefined}
  >
    {title}
    {externalUrl && (
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="external-link-icon" aria-hidden="true" focusable="false">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        <polyline points="15,3 21,3 21,9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
    )}
  </a>
</h2>

<style>
  .blog-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }

  .blog-title a {
    color: var(--text-color);
    text-decoration: none;
    transition: color var(--transition-speed) ease;
  }

  .blog-title a:hover {
    color: var(--accent-color);
  }

  .external-link-icon {
    display: inline-block;
    margin-left: 0.3rem;
    vertical-align: super;
    opacity: 0.7;
    transition: opacity var(--transition-speed) ease, transform var(--transition-speed) ease;
  }

  .blog-title a:hover .external-link-icon {
    opacity: 1;
    transform: translate(2px, -2px);
  }
</style>
