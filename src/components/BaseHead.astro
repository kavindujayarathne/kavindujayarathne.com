---
import { ClientRouter } from 'astro:transitions';

// Define props interface
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: URL | string;
}

// Get values from Astro.props
const {
  title,
  description,
  image = '/splash_low.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Kavindu Jayarathne" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.site)} />
<meta property="og:site_name" content="Kavindu Jayarathne" />

<!-- X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site)} />
<meta name="twitter:site" content="@at_kavindu" />
<meta name="twitter:creator" content="@at_kavindu" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
  rel="stylesheet"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&display=swap"
  rel="stylesheet"
/>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&display=swap" rel="stylesheet">

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="RSS Feed for Kavindu Jayarathne's Blog"
  href="/rss.xml"
/>

<!-- Sitemap -->
<!-- <link rel="sitemap" href="/sitemap-index.xml" /> -->

<!-- Theme Management Script - Blocking script to prevent flash -->
<script is:inline>
  // Immediately apply the saved theme to prevent flash of wrong theme
  (function () {
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'light') {
      document.documentElement.classList.add('light-theme');
    } else {
      document.documentElement.classList.remove('light-theme');
    }
  })();
</script>

<!-- Client-side Routing -->
<ClientRouter />
