---
import SearchIcon from '../assets/icons/SearchIcon.svg?raw';
import MoonIcon from '../assets/icons/MoonIcon.svg?raw';
import SunIcon from '../assets/icons/SunIcon.svg?raw';
import RssIcon from '../assets/icons/RssIcon.svg?raw';
import MenuIcon from '../assets/icons/MenuIcon.svg?raw';
import CloseIcon from '../assets/icons/CloseIcon.svg?raw';
import { SITE } from "../config.ts";
---

<header>
  <div class="logo">
    <a href="/" class="full-name">{SITE.author}</a>
    <a href="/" class="short-name">{SITE.shortName}</a>
  </div>
  <nav>
    <ul class="nav-links">
      <button class="close-nav" aria-label="Close navigation menu">
        <Fragment set:html={CloseIcon} />
      </button>
      <li><a href="/about">About</a></li>
      <li><a href="/blogs">Blogs</a></li>
      <li><a href="/projects">Projects</a></li>
    </ul>
    <div class="mobile-actions">
      <button class="mobile-nav-toggle" aria-label="Toggle navigation menu">
        <Fragment set:html={MenuIcon} />
      </button>
      <div class="action-icons">
        <a href="/search" class="icon-link" aria-label="Search">
          <Fragment set:html={SearchIcon} />
        </a>
        <button id="theme-toggle" aria-label="Toggle theme">
          <span class="moon-icon"><Fragment set:html={MoonIcon} /></span>
          <span class="sun-icon"><Fragment set:html={SunIcon} /></span>
        </button>
        <a href="/rss.xml" class="icon-link" aria-label="RSS Feed">
          <Fragment set:html={RssIcon} />
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  import '../scripts/header';
</script>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
    width: 100%;
    transition: background-color var(--transition-speed) ease;
  }

  .logo a {
    font-family: var(--font-caveat);
    font-size: var(--fs-logo);
    font-weight: 700;
    color: var(--accent-color);
  }

  .short-name {
    display: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: var(--fs-base);
    font-weight: 500;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: var(--accent-color);
    transition: width var(--transition-speed) ease, 
                background-color var(--transition-speed) ease;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .close-nav {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--text-color);
    position: absolute;
    top: 1rem;
    right: 1rem;
    transition: color var(--transition-speed) ease;
  }

  .close-nav:hover {
    color: var(--accent-color);
  }

  .mobile-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .action-icons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #theme-toggle {
    background: none;
    border: none;
    color: var(--text-color);
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 20px;
    height: 20px;
  }

  #theme-toggle:hover {
    color: var(--accent-color);
  }

  /* Hide sun icon in dark mode, moon icon in light mode */
  .sun-icon {
    display: none;
    line-height: 0;
  }

  .moon-icon {
    line-height: 0;
  }

  :global(html[data-theme="light"]) .moon-icon {
    display: none;
  }

  :global(html[data-theme="light"]) .sun-icon {
    display: block;
  }

  .mobile-nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--text-color);
    transition: color var(--transition-speed) ease;
    width: 24px;
    height: 24px;
  }

  .mobile-nav-toggle:hover {
    color: var(--accent-color);
  }

  @media (max-width: 768px) {
    .full-name {
      display: none;
    }

    .short-name {
      display: block;
    }

    .mobile-nav-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      order: -1; /* Move hamburger menu to the left */
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 70%;
      height: 100vh;
      background-color: var(--background-color);
      flex-direction: column;
      justify-content: center;
      padding: 2rem;
      transition: right var(--transition-speed) ease, 
                  background-color var(--transition-speed) ease;
      z-index: 99;
    }

    .nav-links.active {
      right: 0;
    }

    .nav-links li {
      margin: 1.5rem 0;
      font-size: var(--fs-lg);
    }

    .close-nav {
      display: block;
    }

    .mobile-actions {
      gap: 1rem;
      margin-left: auto; /* Push icons to the right */
    }
  }

  @media (max-width: 480px) {
    .nav-links {
      width: 85%;
    }

    .mobile-actions {
      gap: 0.75rem;
    }
  }
</style>
