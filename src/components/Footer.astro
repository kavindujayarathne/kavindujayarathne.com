---
import SocialIcons from './SocialIcons.astro';
import { SITE } from '../config';
---

<footer>
  <div class="copyright">
    &copy; 2025 - {new Date().getFullYear()} {SITE.author}. All Rights Reserved.
  </div>
  <div class="footer-socials">
    <SocialIcons />
  </div>
</footer>

<style>
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
  }

  .footer-socials {
    min-width: 0;
    max-width: 100%;
  }

  .copyright {
    font-size: var(--fs-meta);
    color: var(--secondary-color);
  }

  @media (max-width: 1100px) {
    footer {
      flex-direction: column-reverse;
      gap: 1rem;
      padding: 0.6rem 0;
      text-align: center;
    }
  }
</style>
