---
import BaseHead from './BaseHead.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { SITE } from '../config';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const { title, description = SITE.description, ogImage, canonicalURL } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={ogImage} canonicalURL={canonicalURL} />

    <!-- Umami Analytics -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="76376600-3d9d-4eb7-9b87-cf31853b44b0"></script>
  </head>
  <body>
    <slot />
    <!-- Vercel Analytics -->
    <Analytics />

    <!-- Vercel SpeedInsights -->
    <SpeedInsights />
  </body>
</html>

<style is:global>
  /* ── Variables ── */
  :root {
    --background-color: #030d13;
    --text-color: #ffffff;
    --accent-color: #64ffda;
    --secondary-color: #8892b0;
    --border-color: rgba(255, 255, 255, 0.1);
    --tag-bg: rgba(100, 255, 218, 0.1);
    --tag-hover-bg: rgba(100, 255, 218, 0.2);
    --transition-speed: 0.3s;

    --fs-xs:      0.75rem;
    --fs-sm:      0.8rem;
    --fs-meta:    0.875rem;
    --fs-base:    1rem;
    --fs-lg:      1.1rem;
    --fs-xl:      1.125rem;
    --fs-2xl:     1.25rem;
    --fs-3xl:     1.5rem;
    --fs-4xl:     1.8rem;
    --fs-logo:    3rem;
    --fs-display: 6rem;
  }

  html[data-theme="light"] {
    --background-color: #faf0d2;
    --text-color: #212529;
    --secondary-color: #495057;
    --accent-color: black;
    --border-color: rgba(0, 0, 0, 0.15);
  }

  /* ── Reset & Base ── */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-google-sans-code);
    background-color: var(--background-color);
    color: var(--text-color);
    scroll-behavior: smooth;
    font-weight: 400;
    font-size: 16px;
  }

  body {
    transition: background-color var(--transition-speed) ease,
                color var(--transition-speed) ease;
  }

  a {
    color: var(--text-color);
    text-decoration: none;
    transition: color var(--transition-speed) ease;
  }

  a:hover {
    color: var(--accent-color);
  }

  h1 { font-size: var(--fs-4xl); font-weight: 600; }
  h2 { font-size: var(--fs-3xl); font-weight: 600; }
  h3 { font-size: var(--fs-2xl); font-weight: 600; }
  h4 { font-size: var(--fs-xl); font-weight: 600; }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  /* Theme transition for common elements */
  h1, h2, h3, h4, h5, h6, p, span, div, button, input, textarea, select, li {
    transition: color var(--transition-speed) ease,
                background-color var(--transition-speed) ease,
                border-color var(--transition-speed) ease;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    :root {
      --fs-4xl:  1.5rem;
      --fs-3xl:  1.35rem;
      --fs-2xl:  1.15rem;
    }

    html {
      font-size: 15px;
    }
  }

  @media (max-width: 480px) {
    :root {
      --fs-logo: 2rem;
    }

    html {
      font-size: 14px;
    }
  }
</style>

<script>
  import '../scripts/theme';
</script>
