---
import PageLayout from './PageLayout.astro';
import { SITE } from '../config';
import { formatDate, getReadingTime, slugifyTag } from '../utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  modDate?: Date | null;
  tags: string[];
  ogImage?: string;
  canonicalURL?: string;
  body?: string;
}

const { title, description, pubDate, modDate, tags, ogImage, canonicalURL, body } = Astro.props;
const formattedPubDate = formatDate(pubDate);
const formattedModDate = modDate ? formatDate(modDate) : undefined;
const readingTime = body ? getReadingTime(body) : undefined;
---

<PageLayout title={`${title} | ${SITE.title}`} description={description} ogImage={ogImage} canonicalURL={canonicalURL}>
  <div class="content-container blog-container align-top">
    <article class="blog-content prose" data-pagefind-body>
      <header>
        <h1>{title}</h1>
        <div class="blog-meta">
          <span class="blog-date"><time datetime={pubDate.toISOString()}>{formattedPubDate}</time>{readingTime && (<><span class="separator">&bull;</span><span>{readingTime}</span></>)}</span>
          {formattedModDate && (
            <span class="blog-updated">Updated: <time datetime={modDate!.toISOString()}>{formattedModDate}</time></span>
          )}
        </div>
        <div class="blog-tags">
          {tags.map(tag => (
            <a href={`/tags/${slugifyTag(tag)}`} class="tag">
              {tag}
            </a>
          ))}
        </div>
      </header>
      <div class="content">
        <slot />
      </div>
    </article>
  </div>
</PageLayout>

<script>
  import '../scripts/copy-code';
</script>

<style>
  .blog-container {
    width: 100%;
  }

  .blog-content {
    min-width: 0;
    width: 100%;
  }

  header {
    margin-bottom: 1rem;
  }

  h1 {
    margin-bottom: 0.5rem;
    color: var(--accent-color);
  }

  .blog-meta {
    display: flex;
    flex-direction: column;
    font-size: 1rem;
    color: var(--secondary-color);
    gap: 0.1rem;
  }

  .blog-updated {
    font-style: italic;
  }

  .separator {
    margin: 0 0.4rem;
    font-weight: bold;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: var(--fs-sm);
    background-color: var(--tag-bg);
    color: var(--accent-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: background-color var(--transition-speed) ease;
  }

  .tag:hover {
    background-color: var(--tag-hover-bg);
  }

  .content {
    font-size: var(--fs-lg);
    line-height: 1.8;
    color: var(--secondary-color);
    width: 100%;
  }

  /* Content styles */
  .content :global(h2) {
    margin: 1rem 0 1.5rem;
    color: var(--text-color);
    scroll-margin-top: 100px;
    position: relative;
  }

  .content :global(h2)::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 3rem;
    height: 3px;
    background-color: var(--accent-color);
    opacity: 0.7;
  }

  .content :global(h3) {
    margin: 2.5rem 0 1rem;
    color: var(--text-color);
    scroll-margin-top: 100px;
  }

  .content :global(h4) {
    margin: 2rem 0 0.8rem;
    color: var(--text-color);
    scroll-margin-top: 100px;
  }

  .content :global(p) {
    margin-bottom: 1.2rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 1rem 0 1.2rem 2rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(code:not(pre code)) {
    font-family: var(--font-google-sans-code);
    font-size: 0.9em;
    background-color: rgba(100, 255, 218, 0.1);
    color: var(--accent-color);
    padding: 0.2em 0.4em;
    border-radius: 3px;
    white-space: nowrap;
  }

  .content :global(.code-block-wrapper) {
    position: relative;
    margin: 1.5rem 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .content :global(pre) {
    background-color: #1a2638;
    padding: 1.2rem;
    border-radius: 6px;
    overflow-x: auto;
    border: 1px solid rgba(100, 255, 218, 0.1);
    width: 100%;
    min-width: 0;
  }

  .content :global(pre code) {
    font-family: var(--font-google-sans-code);
    font-size: var(--fs-meta);
    line-height: 1.6;
    display: block;
    color: #e6e6e6;
    white-space: pre;
  }

  /* Copy button styles */
  .content :global(.copy-button) {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.35rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    opacity: 0;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .content :global(.code-block-wrapper:hover .copy-button) {
    opacity: 1;
  }

  .content :global(.copy-button:hover) {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }

  .content :global(.copy-button.copied) {
    background: rgba(100, 255, 218, 0.1);
    color: var(--accent-color);
    border-color: rgba(100, 255, 218, 0.2);
  }

  .content :global(.copy-button svg) {
    width: 16px;
    height: 16px;
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--accent-color);
    padding: 0.8rem 1.2rem;
    margin: 1.5rem 0;
    border-radius: 0 4px 4px 0;
  }

  .content :global(blockquote p) {
    margin-bottom: 0.5rem;
    font-style: italic;
    color: var(--secondary-color);
  }

  .content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .content :global(strong) {
    color: var(--text-color);
    font-weight: 600;
  }

  .content :global(img) {
    border-radius: 8px;
    margin: 0 auto;
  }

  .content :global(img + em) {
    display: block;
    text-align: center;
    font-size: var(--fs-meta);
    color: var(--secondary-color);
    margin-bottom: 2rem;
  }

  .content :global(u) {
    text-decoration-color: var(--accent-color);
    text-decoration-thickness: 2px;
  }

  /* Responsive styles */
  @media (max-width: 768px) {
    .blog-container {
      padding: 1rem;
    }
  }
</style>
