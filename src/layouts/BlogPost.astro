---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;
const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} | Kavindu Jayarathne`} description={description}>
  <div class="content-container blog-container align-top">
    <article class="blog-content">
      <header>
        <h1>{title}</h1>
        <div class="metadata">
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          <div class="tags">
            {
              tags.map(tag => (
                <a href={`/tags/${tag.toLowerCase()}`} class="tag">
                  {tag}
                </a>
              ))
            }
          </div>
        </div>
      </header>
      <div class="content">
        <slot />
      </div>
    </article>
  </div>
</Layout>

<script>
  function setupCodeBlocks() {
    document.querySelectorAll('pre').forEach(pre => {
      // Create copy button
      const copyButton = document.createElement('button');
      copyButton.className = 'copy-button';
      copyButton.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
      `;
      copyButton.setAttribute('aria-label', 'Copy code');
      copyButton.setAttribute('title', 'Copy code');

      // Create wrapper for the pre element
      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';

      // Insert wrapper before pre
      pre.parentNode?.insertBefore(wrapper, pre);

      // Move pre into wrapper
      wrapper.appendChild(pre);

      // Add copy button to wrapper
      wrapper.appendChild(copyButton);

      // Add copy functionality
      copyButton.addEventListener('click', async () => {
        const code = pre.querySelector('code')?.textContent || '';

        try {
          await navigator.clipboard.writeText(code);
          copyButton.classList.add('copied');
          copyButton.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          `;

          // Reset button after 2 seconds
          setTimeout(() => {
            copyButton.classList.remove('copied');
            copyButton.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            `;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy code:', err);
        }
      });
    });
  }

  // Setup on initial load
  setupCodeBlocks();

  // Setup after Astro transitions
  document.addEventListener('astro:after-swap', setupCodeBlocks);
</script>

<style>
  .blog-container {
    width: 100%;
  }

  .blog-content {
    /* display: flex; */
    /* flex-direction: column; */
    /* flex: 1; */
    min-width: 0;
    width: 100%;
  }

  header {
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 2rem);
    margin-bottom: 0.5rem;
    color: var(--accent-color);
  }

  .metadata {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  time {
    font-size: 0.9rem;
    color: var(--secondary-color);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.8rem;
    background-color: rgba(100, 255, 218, 0.1);
    color: var(--accent-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .tag:hover {
    background-color: rgba(100, 255, 218, 0.2);
  }

  .content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--secondary-color);
    width: 100%;
  }

  /* Content styles */
  .content :global(h2) {
    font-size: 1.8rem;
    margin: 1rem 0 1.5rem;
    color: var(--text-color);
    scroll-margin-top: 100px;
    position: relative;
  }

  .content :global(h2)::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 3rem;
    height: 3px;
    background-color: var(--accent-color);
    opacity: 0.7;
  }

  .content :global(h3) {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    color: var(--text-color);
    scroll-margin-top: 100px;
  }

  .content :global(h4) {
    font-size: 1.3rem;
    margin: 2rem 0 0.8rem;
    color: var(--text-color);
    scroll-margin-top: 100px;
  }

  .content :global(p) {
    margin-bottom: 1.2rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 1rem 0 1.2rem 2rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(code:not(pre code)) {
    font-family: 'Fira Code', monospace;
    font-size: 0.9em;
    background-color: rgba(100, 255, 218, 0.1);
    color: var(--accent-color);
    padding: 0.2em 0.4em;
    border-radius: 3px;
    white-space: nowrap;
  }

  .content :global(.code-block-wrapper) {
    position: relative;
    margin: 1.5rem 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .content :global(pre) {
    background-color: #1a2638;
    padding: 1.2rem;
    border-radius: 6px;
    overflow-x: auto;
    border: 1px solid rgba(100, 255, 218, 0.1);
    width: 100%;
    min-width: 0;
  }

  .content :global(pre code) {
    font-family: 'Fira Code', monospace;
    font-size: 0.9rem;
    line-height: 1.6;
    display: block;
    color: #e6e6e6;
    white-space: pre;
  }

  /* Copy button styles */
  .content :global(.copy-button) {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.35rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    opacity: 0;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .content :global(.code-block-wrapper:hover .copy-button) {
    opacity: 1;
  }

  .content :global(.copy-button:hover) {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }

  .content :global(.copy-button.copied) {
    background: rgba(100, 255, 218, 0.1);
    color: var(--accent-color);
    border-color: rgba(100, 255, 218, 0.2);
  }

  .content :global(.copy-button svg) {
    width: 16px;
    height: 16px;
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--accent-color);
    padding: 0.8rem 1.2rem;
    margin: 1.5rem 0;
    /* background-color: rgba(100, 255, 218, 0.05); */
    border-radius: 0 4px 4px 0;
  }

  .content :global(blockquote p) {
    margin-bottom: 0.5rem;
    font-style: italic;
    color: var(--secondary-color);
  }

  .content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .content :global(strong) {
    color: var(--text-color);
    font-weight: 600;
  }

  .content :global(img) {
    border-radius: 8px;
    margin: 0 auto;
  }

  .content :global(img + em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: var(--secondary-color);
    margin-bottom: 2rem;
  }

  .content :global(a) {
    color: var(--accent-color);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent-color);
    transition: border-bottom-style 0.3s ease;
  }

  .content :global(a:hover) {
    border-bottom-style: solid;
  }

  .content :global(u) {
    text-decoration-color: var(--accent-color);
    text-decoration-thickness: 2px;
  }

  /* Responsive styles */
  @media (max-width: 768px) {
    .blog-container {
      padding: 1rem;
    }

    h1 {
      font-size: 1.8rem;
    }

    .content {
      font-size: 1rem;
    }
  }
</style>
