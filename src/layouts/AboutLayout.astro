---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <div class="about">
    <slot />
    <div class="social-container"></div>
  </div>
</Layout>

<style>
  .about {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--section-padding);
  }

  .about :global(ul) {
    margin: 1rem 0 1.2rem 2rem;
    color: var(--secondary-color);
  }

  .about :global(li) {
    margin-bottom: 0.5rem;
  }

  .about :global(strong) {
    color: var(--text-color);
    font-weight: 600;
  }

  :global(h2) {
    color: var(--text-color);
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  :global(h2:first-of-type) {
    font-size: 1.8rem;
    margin-top: 0;
  }

  :global(p) {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--secondary-color);
    margin-bottom: 1rem;
  }

  .social-container {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }
</style>
