---
import PageLayout from './PageLayout.astro';
import type { SchemaEntry } from '../components/StructuredData.astro';

const { frontmatter } = Astro.props;
const structuredData: SchemaEntry[] = [{ type: 'Person' }];
---

<PageLayout title={frontmatter.title} description={frontmatter.description} structuredData={structuredData}>
  <div class="content-container align-top">
    <article class="about prose">
      <slot />
    </article>
  </div>
</PageLayout>

<style>
  .about :global(h1) {
    font-style: italic;
    color: var(--text-color);
    margin-bottom: 1rem;
  }

  .about :global(h2) {
    color: var(--text-color);
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }

  .about :global(p) {
    font-size: var(--fs-lg);
    line-height: 1.8;
    color: var(--secondary-color);
    margin-bottom: 1rem;
  }

  .about :global(ul) {
    margin: 1rem 0 1.2rem 2rem;
    color: var(--secondary-color);
  }

  .about :global(li) {
    margin-bottom: 0.5rem;
  }

  .about :global(strong) {
    color: var(--text-color);
    font-weight: 600;
  }
</style>
